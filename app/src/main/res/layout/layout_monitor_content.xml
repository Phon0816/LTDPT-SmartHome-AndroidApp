<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshMonitor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="96dp">

            <!-- Device List (shown when no device selected) -->
            <LinearLayout
                android:id="@+id/layoutDeviceList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn thiết bị để xem lịch sử"
                    android:textColor="#1E293B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerMonitorDevices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/layoutMonitorLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="#3B82F6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Đang tải dữ liệu..."
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Empty State -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonitorEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="36dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E0F2FE"
                        app:strokeWidth="0dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_footer_monitor"
                            app:tint="#3B82F6" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/txtEmptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có dữ liệu"
                        android:textColor="#1E293B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/txtEmptyDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thiết bị chưa gửi dữ liệu cảm biến."
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefresh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Làm mới"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#3B82F6"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Content Container -->
            <LinearLayout
                android:id="@+id/layoutMonitorContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- CARD 1: Header with Device Info and Metrics -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Device Header Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:id="@+id/btnBackToDeviceList"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_revert"
                                app:tint="#64748B"
                                android:layout_marginEnd="12dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:clickable="true"
                                android:focusable="true" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtMonitorDeviceName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thiết bị 1"
                                    android:textColor="#1E293B"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        app:srcCompat="@drawable/ic_clock"
                                        app:tint="#64748B"
                                        android:layout_marginEnd="4dp" />

                                    <TextView
                                        android:id="@+id/txtMonitorLastUpdate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Cập nhật: --:--"
                                        android:textColor="#64748B"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cardMonitorStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#D1FAE5"
                                    app:strokeWidth="0dp"
                                    android:layout_marginEnd="8dp">

                                    <TextView
                                        android:id="@+id/txtMonitorStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="SAFE"
                                        android:textColor="#065F46"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:paddingTop="6dp"
                                        android:paddingBottom="6dp" />
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnHeaderRefresh"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:padding="0dp"
                                    app:backgroundTint="#F1F5F9"
                                    app:cornerRadius="20dp"
                                    app:elevation="0dp"
                                    app:icon="@drawable/ic_notifications"
                                    app:iconGravity="textStart"
                                    app:iconPadding="0dp"
                                    app:iconSize="20dp"
                                    app:iconTint="#64748B" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Current Metrics Grid -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Temperature -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="#FEF2F2"
                                android:padding="12dp"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🌡️ Nhiệt độ"
                                    android:textColor="#DC2626"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/txtMonitorCurrentTemp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--°C"
                                    android:textColor="#1E293B"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Humidity -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="#EFF6FF"
                                android:padding="12dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💧 Độ ẩm"
                                    android:textColor="#2563EB"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/txtMonitorCurrentHumid"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--%"
                                    android:textColor="#1E293B"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- MQ2 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="#FEF3C7"
                                android:padding="12dp"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💨 MQ2"
                                    android:textColor="#D97706"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/txtMonitorCurrentMQ2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="#1E293B"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- MQ135 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="#F0FDF4"
                                android:padding="12dp"
                                android:layout_marginStart="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🌫️ MQ135"
                                    android:textColor="#059669"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/txtMonitorCurrentMQ135"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="#1E293B"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Time Filter Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFilter24h"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="24 giờ"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="4dp"
                        app:backgroundTint="#F1F5F9"
                        app:cornerRadius="8dp"
                        app:elevation="0dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFilter7d"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="7 ngày"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        app:backgroundTint="#F1F5F9"
                        app:cornerRadius="8dp"
                        app:elevation="0dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFilter30d"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="30 ngày"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginStart="4dp"
                        app:backgroundTint="#F1F5F9"
                        app:cornerRadius="8dp"
                        app:elevation="0dp"
                        app:strokeWidth="0dp" />
                </LinearLayout>

                <!-- CARD 2: Temperature & Humidity Charts (Merged) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌡️ Nhiệt độ &amp; 💧 Độ ẩm"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartTemperature"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginBottom="16dp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartHumidity"
                            android:layout_width="match_parent"
                            android:layout_height="200dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD 3: Gas Chart with Toggle -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="💨 Khí Gas"
                                android:textColor="#1E293B"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/gasTabGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleSelection="true"
                                app:selectionRequired="true">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnTabMQ2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:text="MQ2"
                                    android:textColor="#64748B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    app:backgroundTint="#F1F5F9"
                                    app:cornerRadius="8dp"
                                    app:strokeWidth="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnTabMQ135"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:text="MQ135"
                                    android:textColor="#64748B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    app:backgroundTint="#F1F5F9"
                                    app:cornerRadius="8dp"
                                    app:strokeWidth="0dp" />
                            </com.google.android.material.button.MaterialButtonToggleGroup>
                        </LinearLayout>

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartGas"
                            android:layout_width="match_parent"
                            android:layout_height="220dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD 4: Flame Detection Timeline -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Phát hiện lửa"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/txtFlameEmpty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Không có sự kiện phát hiện lửa trong khoảng thời gian đã chọn."
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerFlameTimeline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:overScrollMode="never" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD 5: Recent History -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋 Lịch sử gần đây"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerRecentHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:overScrollMode="never" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

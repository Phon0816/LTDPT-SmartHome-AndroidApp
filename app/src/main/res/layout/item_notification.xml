<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/safehome_card_white"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtNotificationType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:background="#EAF2FF"
                tools:text="INFO"
                tools:textColor="#2563EB" />

            <TextView
                android:id="@+id/txtNotificationReadState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/safehome_text_muted"
                android:textSize="13sp"
                tools:text="Chua doc" />

            <TextView
                android:id="@+id/txtNotificationCreatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="@color/safehome_text_muted"
                android:textSize="13sp"
                tools:text="Hom nay, 10:05" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtNotificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/safehome_text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Canh bao khi gas" />

        <TextView
            android:id="@+id/txtNotificationMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/safehome_text_muted"
            android:textSize="14sp"
            tools:text="Nong do khi gas vuot nguong an toan tai khu vuc bep. Vui long kiem tra ngay." />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

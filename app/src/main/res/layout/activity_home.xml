<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/safehome_background"
            android:fillViewport="true"
            tools:context=".HomeActivity" android:id="@+id/homeScrollView">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <!-- Header Row (Greeting, Name, Notifications, Avatar) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/headerActionContainer">
                <TextView
                    android:id="@+id/txtGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào Phong 👋"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:layout_marginBottom="2dp" />
                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhà của "
                    android:textColor="@color/safehome_text_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/headerActionContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">
                
                <!-- Bell container -->
                <FrameLayout
                    android:id="@+id/bellContainer"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/ic_notifications"
                        app:tint="#1E293B" />
                    <View
                        android:id="@+id/notificationBadge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_badge_dot_green" />
                </FrameLayout>

                <!-- Avatar container -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center_vertical"
                    app:cardCornerRadius="21dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:srcCompat="@drawable/ic_person_safehome" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>

        <!-- Khung an toàn lớn (Safety Score Card) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="0dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:background="@drawable/bg_safety_card_gradient">
                
                <!-- Image Logo trái -->
                <ImageView
                    android:id="@+id/imgShieldLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    app:srcCompat="@drawable/img_shield_house" />
                
                <!-- Text info phải -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/imgShieldLogo"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">
                    
                    <!-- Badge SAFE -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#D1FAE5"
                        app:strokeWidth="0dp"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ SAFE"
                            android:textColor="#065F46"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />
                    </com.google.android.material.card.MaterialCardView>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhà của bạn đang được bảo vệ"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="92%"
                        android:textColor="#10B981"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safety Score ⓘ"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp" />
                    
                    <!-- Time updated -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            app:srcCompat="@drawable/ic_clock"
                            app:tint="#64748B"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cập nhật 10 giây trước"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nút Thêm thiết bị - chỉ hiện khi chưa có device nào -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddDevice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:text="📡  Thêm thiết bị"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#3B82F6"
            app:cornerRadius="16dp"
            app:elevation="2dp"
            app:icon="@null"/>

        <!-- Tiêu đề mục: Tổng quan cảm biến -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp">
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng cảm biến"
                    android:textColor="@color/safehome_text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem chi tiết >"
                android:textColor="#4F8DF7"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Thanh cuộn ngang các ô cảm biến -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="8dp">
                
                <!-- Ô 1: Nhiệt độ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="175dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center_horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            app:cardCornerRadius="23dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_temp"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhiệt độ"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/txtTempValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/viewTempDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_badge_dot_grey"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/txtTempStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa kết nối"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ô 2: Độ ẩm -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="175dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center_horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            app:cardCornerRadius="23dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_humidity"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ ẩm"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/txtHumidValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/viewHumidDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_badge_dot_grey"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/txtHumidStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa kết nối"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ô 3: Khí gas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="175dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center_horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            app:cardCornerRadius="23dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_gas"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khí gas"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/txtGasValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/viewGasDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_badge_dot_grey"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/txtGasStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa kết nối"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ô 4: Còi báo (Buzzer) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="175dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center_horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            app:cardCornerRadius="23dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_buzzer"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Còi báo"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/txtBuzzerValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/viewBuzzerDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_badge_dot_grey"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/txtBuzzerStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa kết nối"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ô 5: Phát hiện lửa -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="175dp"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center_horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            app:cardCornerRadius="23dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC"
                            app:strokeWidth="0dp"
                            android:layout_marginBottom="8dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                app:srcCompat="@drawable/ic_fire"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phát hiện lửa"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/txtFireValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N/A"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:id="@+id/viewFireDot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_badge_dot_grey"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/txtFireStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chưa kết nối"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>

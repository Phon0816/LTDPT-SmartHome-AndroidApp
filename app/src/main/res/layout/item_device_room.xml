<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="12dp"
    android:orientation="vertical"
    android:padding="16dp"
    android:elevation="8dp"
    android:outlineProvider="background"
    android:background="@drawable/bg_placeholder_glass_card">

    <!-- Header Row (Icon, Name, Code, Status) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Room Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRoomIcon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="21dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/safehome_blue_soft"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_room"
                app:tint="@color/safehome_blue_deep" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Room Name & Code -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/cardRoomIcon"
            android:layout_toStartOf="@id/layoutRoomStatus"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtDeviceRoomName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng khách"
                android:textColor="@color/safehome_text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtDeviceRoomCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code: DEV01"
                android:textColor="@color/safehome_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status (Online/Offline) -->
        <LinearLayout
            android:id="@+id/layoutRoomStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View
                android:id="@+id/viewRoomStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_badge_dot_green" />
            <TextView
                android:id="@+id/txtRoomStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoạt động"
                android:textColor="#22C55E"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- LED Lights Controls Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Điều khiển hệ thống đèn"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- LED 1 -->
        <LinearLayout
            android:id="@+id/layoutLed1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewLed1Bg"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_led_active_glow"
                    android:visibility="invisible" />
                <ImageView
                    android:id="@+id/imgLed1"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="#94A3B8" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đèn 1"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- LED 2 -->
        <LinearLayout
            android:id="@+id/layoutLed2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewLed2Bg"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_led_active_glow"
                    android:visibility="invisible" />
                <ImageView
                    android:id="@+id/imgLed2"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="#94A3B8" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đèn 2"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- LED 3 -->
        <LinearLayout
            android:id="@+id/layoutLed3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewLed3Bg"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_led_active_glow"
                    android:visibility="invisible" />
                <ImageView
                    android:id="@+id/imgLed3"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="#94A3B8" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đèn 3"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- LED 4 -->
        <LinearLayout
            android:id="@+id/layoutLed4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewLed4Bg"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_led_active_glow"
                    android:visibility="invisible" />
                <ImageView
                    android:id="@+id/imgLed4"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="#94A3B8" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đèn 4"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- LED 5 -->
        <LinearLayout
            android:id="@+id/layoutLed5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">
                <View
                    android:id="@+id/viewLed5Bg"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_led_active_glow"
                    android:visibility="invisible" />
                <ImageView
                    android:id="@+id/imgLed5"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="#94A3B8" />
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đèn 5"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

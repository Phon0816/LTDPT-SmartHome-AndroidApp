<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="175dp"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#F1F5F9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Khung hình tròn chứa icon cảm biến -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconBg"
            android:layout_width="46dp"
            android:layout_height="46dp"
            app:cardBackgroundColor="#F0F7FF"
            app:cardCornerRadius="23dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imgSensorIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person_safehome"
                app:tint="@color/safehome_primary_blue" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Tên cảm biến -->
        <TextView
            android:id="@+id/txtSensorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nhiệt độ"
            android:textColor="@color/safehome_text_muted"
            android:textSize="12sp"
            android:textStyle="normal" />

        <!-- Chỉ số cảm biến -->
        <TextView
            android:id="@+id/txtSensorValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="25.2°C"
            android:textColor="@color/safehome_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Trạng thái (Bình thường / Cảnh báo) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Chấm xanh tròn nhỏ -->
            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_badge_dot_green" />

            <TextView
                android:id="@+id/txtSensorStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Bình thường"
                android:textColor="#22C55E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SafeHome" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/safehome_primary_blue</item>
        <item name="colorPrimaryVariant">@color/safehome_blue_deep</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/safehome_green</item>
        <item name="colorSecondaryVariant">@color/safehome_green</item>
        <item name="colorOnSecondary">@color/safehome_text_dark</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:statusBarColor">@color/safehome_background</item>
        <item name="android:navigationBarColor">@color/safehome_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
